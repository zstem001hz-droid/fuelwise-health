# ─── FuelWise Health — Frontend Environment Variables ─────────
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to GitHub.

# ─── OAuth / Auth Provider ───────────────────────────────────
# Optional frontend-only provider client ID (only if your auth start endpoint needs it).
VITE_AUTH_PROVIDER_CLIENT_ID=

# ─── Backend API ──────────────────────────────────────────────
# The URL of the deployed backend server on Render.com.
# Use http://localhost:3000 for local development.
# See: https://github.com/zstem001hz-droid/backend-server
VITE_API_BASE_URL=

# Optional auth endpoint paths exposed by your backend.
# Defaults in app code:
# - VITE_AUTH_START_PATH=/api/auth/connect
# - VITE_AUTH_CALLBACK_PATH=/api/auth/callback
VITE_AUTH_START_PATH=/api/auth/connect
VITE_AUTH_CALLBACK_PATH=/api/auth/callback

# Optional activities endpoint path.
# Defaults in app code try these paths in order:
# - VITE_ACTIVITIES_PATH (if provided)
# - /api/hefit/activities
# - /api/activities
# - /api/strava/activities
VITE_ACTIVITIES_PATH=/api/hefit/activities