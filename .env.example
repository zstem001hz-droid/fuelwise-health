# ─── FuelWise Health — Frontend Environment Variables ─────────
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to GitHub.

# ─── Backend API ──────────────────────────────────────────────
# Base URL for your API server.
# Examples:
# - Local backend: http://localhost:3000
# - Hosted backend: https://hefitapi.com
VITE_API_BASE_URL=

# ─── OAuth / Auth Provider (optional) ─────────────────────────
# Optional frontend-only provider client ID (only if your auth start endpoint needs it).
VITE_AUTH_PROVIDER_CLIENT_ID=

# ─── OAuth Endpoint Paths (optional) ──────────────────────────
# If omitted, app defaults are used.
VITE_AUTH_START_PATH=/api/auth/connect
VITE_AUTH_CALLBACK_PATH=/api/auth/callback

# ─── Activity Data Endpoint (optional) ────────────────────────
# Used by dashboard activity sync.
# Default fallback order in app: /api/hefit/activities, /api/activities, /api/strava/activities
VITE_ACTIVITIES_PATH=/api/hefit/activities

# ─── Development Options ──────────────────────────────────────
# Set to true to bypass OAuth and force-authenticate a local dev user.
# Useful for quickly rendering /dashboard while backend auth is still being wired.
VITE_DEV_BYPASS_AUTH=false
