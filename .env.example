# ─── FuelWise Health — Frontend Environment Variables ─────────
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to GitHub.

# ─── Strava OAuth ─────────────────────────────────────────────
# Your Strava Client ID (found at https://www.strava.com/settings/api)
# Note: Only the Client ID goes here — NEVER the Client Secret.
# The Client Secret lives exclusively in the backend-server repo.
VITE_STRAVA_CLIENT_ID=

# ─── Backend API ──────────────────────────────────────────────
# The URL of the deployed backend server on Render.com.
# Use http://localhost:3000 for local development.
# See: https://github.com/zstem001hz-droid/backend-server
VITE_API_BASE_URL=